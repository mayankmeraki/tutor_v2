# LLM Provider: "anthropic" or "openrouter" (openrouter recommended — returns actual cost data)
LLM_PROVIDER=openrouter
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Model overrides (defaults in config.py)
# TUTOR_MODEL=claude-sonnet-4-6
# PLANNING_MODEL=claude-sonnet-4-6
# RESEARCH_MODEL=claude-haiku-4-5-20251001
# SUMMARIZATION_MODEL=claude-haiku-4-5-20251001

# PostgreSQL
DB_HOST=localhost
DB_PORT=5433
DB_NAME=capacity
DB_USER=capacity_service_user
DB_PASSWORD=

# MongoDB
MONGODB_URI=

# Auth
MOCKUP_JWT_SECRET=

# Server
PORT=3001

# CORS (comma-separated origins for production)
# CORS_ORIGINS=https://dev.seekcapacity.ai,https://seekcapacity.ai
